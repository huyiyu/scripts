def check_kubelet_runtime(cluster: str) -> Tuple[bool, str]:
    success, output = run_cmd("grep 'container-runtime-endpoint' /var/lib/kubelet/config.yaml")
    if success and 'cri-docker' in output:
        return True, "kubelet 已配置 cri-dockerd"
    success, output = run_cmd("ps aux | grep kubelet | grep -o 'container-runtime[^ ]*'")
    if success and 'cri-docker' in output:
        return True, "kubelet 进程使用 cri-dockerd"
    return False, "kubelet 未配置 cri-dockerd"

def run_cmd(cmd: str) -> tuple:
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=30)
        return result.returncode == 0, result.stdout
    except:
        return False, ""

