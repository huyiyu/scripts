def check_deployment_volumes(cluster: str, namespace: str, name: str) -> Tuple[bool, str]:
    success, output = run_kubectl(cluster, f"get deployment {name} -n {namespace} -o json")
    if not success:
        return False, f"Deployment {name} 不存在"
    try:
        data = json.loads(output)
        volumes = data.get('spec', {}).get('template', {}).get('spec', {}).get('volumes', [])
        has_configmap = any(v.get('configMap') for v in volumes)
        has_secret = any(v.get('secret') for v in volumes)
        if has_configmap and has_secret:
            return True, f"Deployment 同时使用 ConfigMap 和 Secret"
        errors = []
        if not has_configmap:
            errors.append("未使用 ConfigMap")
        if not has_secret:
            errors.append("未使用 Secret")
        return False, f"Deployment: {', '.join(errors)}"
    except:
        return False, "解析 Deployment 配置失败"

def check_calico_ready(cluster: str) -> Tuple[bool, str]:
    success, output = run_kubectl(cluster, "get pods -n calico-system -o json")
    if not success:
        return False, "Calico 未安装"
    try:
        data = json.loads(output)
        pods = data.get('items', [])
        if not pods:
            return False, "Calico 未安装"
        running = sum(1 for pod in pods if pod.get('status', {}).get('phase') == 'Running')
        if running == len(pods):
            return True, f"Calico 全部运行中 ({running}/{len(pods)})"
        return False, f"Calico Pod 状态: {running}/{len(pods)} 运行中"
    except:
        return False, "解析 Calico 状态失败"

def check_pod_resources(cluster: str, namespace: str, name: str) -> Tuple[bool, str]:
    success, output = run_kubectl(cluster, f"get pod -n {namespace} -o json")
    if not success:
        return False, "无法获取 Pod 列表"
    try:
        data = json.loads(output)
        for pod in data.get('items', []):
            if name in pod.get('metadata', {}).get('name', ''):
                containers = pod.get('spec', {}).get('containers', [])
                for container in containers:
                    limits = container.get('resources', {}).get('limits', {})
                    if limits.get('memory') or limits.get('cpu'):
                        return True, f"Pod 已配置资源限制"
                return False, f"Pod 未配置资源限制"
        return False, f"Pod {name} 不存在"
    except:
        return False, "解析 Pod 配置失败"

def check_node_ready(cluster: str) -> Tuple[bool, str]:
    success, output = run_kubectl(cluster, "get nodes -o json")
    if not success:
        return False, "无法获取节点状态"
    try:
        data = json.loads(output)
        nodes = data.get('items', [])
        ready_count = 0
        for node in nodes:
            for cond in node.get('status', {}).get('conditions', []):
                if cond.get('type') == 'Ready' and cond.get('status') == 'True':
                    ready_count += 1
        if ready_count == len(nodes):
            return True, f"所有节点 Ready ({ready_count}/{len(nodes)})"
        return False, f"节点状态: {ready_count}/{len(nodes)} Ready"
    except:
        return False, "解析节点状态失败"

