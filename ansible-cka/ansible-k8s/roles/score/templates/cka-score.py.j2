# ============ 输出函数 ============

def print_header():
    width = 70
    print()
    print(f"{Colors.CYAN}{'=' * width}{Colors.END}")
    print(f"{Colors.BOLD}{Colors.CYAN}{'CKA 考试评分系统 (Cluster3)':^{width}}{Colors.END}")
    print(f"{Colors.CYAN}{'=' * width}{Colors.END}")
    print()
    print(f"  {Colors.DIM}考试时间:{Colors.END} {Colors.YELLOW}{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}{Colors.END}")
    print(f"  {Colors.DIM}通过分数:{Colors.END} {Colors.GREEN}{PASSING_SCORE}/{TOTAL_SCORE}{Colors.END}")
    print(f"  {Colors.DIM}题目数量:{Colors.END} {Colors.BLUE}{QUESTION_COUNT} 题{Colors.END}")
    print(f"  {Colors.DIM}运行节点:{Colors.END} {Colors.MAGENTA}cluster3 (cka000016){Colors.END}")
    print()

def print_question_result(qid: str, name: str, passed: bool, details: List[str]):
    if passed:
        status_icon = f"{Colors.GREEN}✓{Colors.END}"
        status_text = f"{Colors.GREEN}PASS{Colors.END}"
        score_text = f"{Colors.GREEN}+{SCORE_PER_QUESTION:.1f}分{Colors.END}"
    else:
        status_icon = f"{Colors.RED}✗{Colors.END}"
        status_text = f"{Colors.RED}FAIL{Colors.END}"
        score_text = f"{Colors.RED}+0分{Colors.END}"
    
    print(f"  {Colors.BOLD}{qid}{Colors.END} {Colors.DIM}-{Colors.END} {name}")
    print(f"  {' ' * len(qid)} {status_icon} {status_text}  {score_text}")
    
    for detail in details:
        if detail.startswith("✓"):
            icon = f"{Colors.GREEN}✓{Colors.END}"
            text = detail[1:].strip()
            print(f"      {icon} {Colors.DIM}{text}{Colors.END}")
        else:
            icon = f"{Colors.RED}✗{Colors.END}"
            text = detail[1:].strip() if detail.startswith("✗") else detail
            print(f"      {icon} {text}")
    print()

def print_summary(score: float, passed: int, failed: int):
    width = 70
    print(f"{Colors.CYAN}{'-' * width}{Colors.END}")
    print(f"{Colors.BOLD}{'评分总结':^{width}}{Colors.END}")
    print(f"{Colors.CYAN}{'-' * width}{Colors.END}")
    print()
    
    score_pct = (score / TOTAL_SCORE) * 100
    if score >= PASSING_SCORE:
        score_color = Colors.GREEN
        result_icon = "✓"
    else:
        score_color = Colors.RED
        result_icon = "✗"
    
    print(f"  {Colors.BOLD}总得分:{Colors.END} {score_color}{score:.1f}/{TOTAL_SCORE} ({score_pct:.1f}%){Colors.END} {score_color}{result_icon}{Colors.END}")
    print()
    print(f"  {Colors.GREEN}● 通过题目:{Colors.END} {passed} 题")
    print(f"  {Colors.RED}● 未通过:{Colors.END} {failed} 题")
    print(f"  {Colors.DIM}○ 未开始:{Colors.END} {QUESTION_COUNT - passed - failed} 题")
    print()
    
    print(f"{Colors.CYAN}{'-' * width}{Colors.END}")
    if score >= PASSING_SCORE:
        print(f"{Colors.GREEN}{Colors.BOLD}{'恭喜通过 CKA 考试！':^{width}}{Colors.END}")
    else:
        needed = PASSING_SCORE - score
        print(f"{Colors.YELLOW}{f'还需 {needed:.1f} 分通过考试':^{width}}{Colors.END}")
    print(f"{Colors.CYAN}{'-' * width}{Colors.END}")
    print()
    print(f"  {Colors.DIM}评分规则:{Colors.END}")
    print(f"  • 每题满分 {SCORE_PER_QUESTION:.2f} 分")
    print(f"  • 全对得分，错一个检查点不得分")
    print()

def main():
    print_header()
    
    total_score = 0.0
    passed_count = 0
    failed_count = 0
    
    for qid, config in QUESTIONS.items():
        cluster = config["cluster"]
        namespace = config["namespace"]
        name = config["name"]
        checks = config["checks"]
        
        details = []
        all_passed = True
        
        for check in checks:
            try:
                if check.__name__ in ['check_calico_ready', 'check_cri_dockerd_installed', 
                                       'check_kubelet_runtime', 'check_crd_list', 'check_certificate_doc']:
                    passed, msg = check(cluster)
                else:
                    passed, msg = check(cluster, namespace)
                
                if passed:
                    details.append(f"✓ {msg}")
                else:
                    details.append(f"✗ {msg}")
                    all_passed = False
            except Exception as e:
                details.append(f"✗ 检查异常: {str(e)}")
                all_passed = False
        
        if all_passed:
            total_score += SCORE_PER_QUESTION
            passed_count += 1
        else:
            failed_count += 1
        
        print_question_result(qid, name, all_passed, details)
    
    print_summary(total_score, passed_count, failed_count)
    return 0 if total_score >= PASSING_SCORE else 1

if __name__ == "__main__":
    sys.exit(main())
