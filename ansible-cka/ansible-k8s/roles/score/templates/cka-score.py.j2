# ============ Q12 专用检查 - TLS 1.2 ============
def check_tls_version(cluster: str, namespace: str, service: str, unused=None) -> Tuple[bool, str]:
    success, output = run_kubectl(cluster, f"get service {service} -n {namespace} -o json")
    if not success:
        return False, f"Service {service} 不存在"
    try:
        data = json.loads(output)
        ports = data.get('spec', {}).get('ports', [])
        https_port = None
        for port in ports:
            if port.get('name') == 'https' or port.get('port') == 443:
                https_port = port.get('nodePort')
                break
        if not https_port:
            return False, "未找到 HTTPS 端口"
        test_cmd = f"echo | openssl s_client -connect localhost:{https_port} -tls1_2 2>&1 | grep 'Protocol'"
        result = subprocess.run(test_cmd, shell=True, capture_output=True, text=True, timeout=10)
        if 'TLSv1.2' in result.stdout or 'TLSv1.3' in result.stdout:
            return True, "TLS 1.2/1.3 配置正确"
        return False, "TLS 版本不符合要求"
    except Exception as e:
        return False, f"检查 TLS 版本失败: {str(e)}"

# ============ 其他检查函数 ============

def check_hpa(cluster: str, namespace: str, name: str) -> Tuple[bool, str]:
    success, output = run_kubectl(cluster, f"get hpa {name} -n {namespace} -o json")
    if not success:
        return False, f"HPA {name} 不存在"
    try:
        data = json.loads(output)
        spec = data.get('spec', {})
        min_replicas = spec.get('minReplicas')
        max_replicas = spec.get('maxReplicas')
        metrics = spec.get('metrics', [])
        cpu_percent = None
        for m in metrics:
            if m.get('type') == 'Resource' and m.get('resource', {}).get('name') == 'cpu':
                cpu_percent = m.get('resource', {}).get('target', {}).get('averageUtilization')
        if min_replicas == 1 and max_replicas == 2 and cpu_percent == 50:
            return True, f"HPA 配置正确 (min={min_replicas}, max={max_replicas}, cpu={cpu_percent}%)"
        return False, f"HPA 配置错误 (min={min_replicas}, max={max_replicas}, cpu={cpu_percent}%)"
    except:
        return False, "解析 HPA 配置失败"

def check_priorityclass(cluster: str, name: str, value: int = None) -> Tuple[bool, str]:
    success, output = run_kubectl(cluster, f"get priorityclass {name} -o json")
    if not success:
        return False, f"PriorityClass {name} 不存在"
    try:
        data = json.loads(output)
        actual_value = data.get('value', 0)
        if value is not None and actual_value != value:
            return False, f"PriorityClass 值={actual_value}, 期望 {value}"
        return True, f"PriorityClass {name} 值={actual_value}"
    except:
        return False, "解析 PriorityClass 失败"

def check_pod_priority(cluster: str, namespace: str, pod_name: str, priority_class: str) -> Tuple[bool, str]:
    success, output = run_kubectl(cluster, f"get pod -n {namespace} -o json")
    if not success:
        return False, "无法获取 Pod 列表"
    try:
        data = json.loads(output)
        for pod in data.get('items', []):
            if pod_name in pod.get('metadata', {}).get('name', ''):
                actual = pod.get('spec', {}).get('priorityClassName', '')
                if actual == priority_class:
                    return True, f"Pod 使用 PriorityClass {priority_class}"
                return False, f"Pod PriorityClass={actual}, 期望 {priority_class}"
        return False, f"Pod {pod_name} 不存在"
    except:
        return False, "解析 Pod 配置失败"

