options {
	directory "/var/cache/bind";
	dnssec-validation auto;
	listen-on-v6 { any; };
        listen-on port 53{any;};
        allow-recursion {
                none;
        };
        allow-transfer {
                none;
        };
        allow-update {
                none;
        };
        allow-query     { any; }; 
};
